<?xml version="1.0" encoding="utf-8"?>
<!-- Transparent illustration art; the foreground already bakes in its margin
     (subject ~64% of canvas), so no inset. The dark background blends with the
     illustration's own dark ink ring where the mask reveals edges. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
  <background android:drawable="@color/ic_launcher_illust_background"/>
  <foreground android:drawable="@mipmap/ic_launcher_illust_foreground"/>
</adaptive-icon>
